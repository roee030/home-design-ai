# ─── ShopTheRoom AI — environment variables ───────────────────────────────
#
# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real API keys.
#
# ── Frontend (Vite) ──────────────────────────────────────────────────────
#
# URL of your deployed Cloudflare Worker API.
# In development: leave empty — Vite proxies /api → http://localhost:8787
# In production:  set to your worker's public URL
VITE_API_URL=https://shoptheroom-api.<your-subdomain>.workers.dev

# ── Cloudflare Worker secrets ─────────────────────────────────────────────
# Set these via Wrangler (NOT in a file):
#   cd workers && wrangler secret put GEMINI_API_KEY
#   cd workers && wrangler secret put FAL_AI_KEY
#
# GEMINI_API_KEY  — Google AI Studio   https://aistudio.google.com/apikey  (free tier)
# FAL_AI_KEY      — fal.ai             https://fal.ai/dashboard/keys
